# ==========================================
# zeroDB .gitignore
# ==========================================

# ------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------
# Prevents leaking OAuth keys, database credentials, 
# and files containing MODE=dev or prod.
.env
.env.*
*.env
backend/.env
frontend/.env
docker-compose.override.yml

# ------------------------------------------
# Node.js / JavaScript / TypeScript
# ------------------------------------------
node_modules/
frontend/node_modules
backend/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
dist/
build/
.next/
out/

# ------------------------------------------
# Python (If your backend uses it)
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.pytest_cache/

# ------------------------------------------
# Logs & Databases
# ------------------------------------------
logs/
*.log
# Ignore local database dumps or test data 
*.sql
*.sqlite
*.sqlite3
*.dump
pgdata/

# ------------------------------------------
# OS Generated Files
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------------------
# IDEs & Code Editors
# ------------------------------------------
.vscode/
.idea/
*.swp
*.swo